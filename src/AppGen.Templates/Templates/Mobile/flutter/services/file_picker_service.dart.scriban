import 'package:file_picker/file_picker.dart';

/// Opens the system file picker. Generated by AppGen.
class FilePickerService {
  Future<FilePickerResult?> pickFiles({
    FileType type = FileType.any,
    bool allowMultiple = false,
  }) =>
      FilePicker.platform.pickFiles(type: type, allowMultiple: allowMultiple);

  Future<String?> pickSavePath({String? fileName}) =>
      FilePicker.platform.saveFile(fileName: fileName);
}
