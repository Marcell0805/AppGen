import 'package:geocoding/geocoding.dart';

/// Forward/reverse geocoding for place search. Generated by AppGen.
class PlaceSearchService {
  Future<List<Location>> searchCoordinates(String address) => locationFromAddress(address);

  Future<List<Placemark>> reverseGeocode(double lat, double lng) =>
      placemarkFromCoordinates(lat, lng);
}
