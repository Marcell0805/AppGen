import 'package:flutter_blue_plus/flutter_blue_plus.dart';

/// Bluetooth LE scanning and connection helpers. Generated by AppGen.
class BluetoothService {
  Stream<List<ScanResult>> scan({Duration timeout = const Duration(seconds: 8)}) async* {
    await FlutterBluePlus.startScan(timeout: timeout);
    yield* FlutterBluePlus.scanResults;
    await FlutterBluePlus.stopScan();
  }

  Future<void> connect(BluetoothDevice device) => device.connect();
}
