<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ portal_name }}</title>
  <link rel="stylesheet" href="css/portal.css">
{{ if password_gate }}
  <style>html:not(.auth-ok) body > :not(#auth-gate) { display: none; }</style>
  <script src="js/auth.js"></script>
{{ end }}
</head>
<body data-nav-scope="landing">
  <div class="landing">
    <img class="landing-logo" src="assets/logo.svg" alt="{{ app_name }}">
    <h1>{{ portal_title }}</h1>
    <p class="subtitle">{{ tagline }}</p>

{{ if search_enabled }}
    <div class="landing-search-wrap no-print">
      <input type="search" id="landing-search" class="landing-search" placeholder="Search portal… (Ctrl+K)" readonly>
    </div>
{{ end }}

    <ol class="landing-nav" data-portal-landing-nav></ol>

    <p class="landing-tagline" data-portal-tagline>{{ home_quote }}</p>

    <p class="site-footer no-print" style="margin-top:2rem">
      Documentation portal — generated by AppGen.
    </p>
  </div>

{{ if search_enabled }}
  <script src="js/vendor/fuse.min.js"></script>
  <script src="js/search-index.js"></script>
  <script src="js/search.js"></script>
{{ end }}
  <script src="js/portal-data.js"></script>
  <script src="js/portal.js"></script>
</body>
</html>
