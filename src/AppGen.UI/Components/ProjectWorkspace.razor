@using AppGen.Core
@using AppGen.Core.Capabilities
@using AppGen.Core.Models
@using AppGen.Engine
@using AppGen.UI.Models
@using AppGen.UI.Services
@inject WizardStateService WizardState
@inject ManifestSaveService ManifestSave
@inject OutputFolderService FolderService
@inject IWebHostEnvironment HostEnvironment
@inject IJSRuntime Js
@implements IDisposable

<fieldset class="panel">
    <legend>Application</legend>
    <div class="form-grid">
        <label>App name</label>
        <input @bind="ApplicationName" @bind:after="SyncState" />

        <label>Root namespace</label>
        <input @bind="RootNamespace" @bind:after="SyncState" placeholder="Defaults to app name" />

        <label>Output folder</label>
        <input @bind="OutputRoot" @bind:after="SyncState" placeholder="e.g. output/MyProduct" />
    </div>
</fieldset>

<fieldset class="panel">
    <legend>About this app</legend>
    <div class="form-grid">
        <label>Tagline</label>
        <input @bind="Tagline" @bind:after="SyncState" placeholder="Short pitch (one line)" />

        <label>Description</label>
        <textarea @bind="Description" @bind:after="SyncState" rows="6" placeholder="Goals, audience, scope…"></textarea>
    </div>
    <p class="hint">Markdown supported (headings, lists, bold). Used in generated READMEs and Documentation vision when not customized.</p>
</fieldset>

<fieldset class="panel">
    <legend>Layers</legend>
    <p class="hint">Each layer generates into its own folder under the output root: <code>{AppName}</code> (manifest), <code>{AppName} Doc</code>, <code>{AppName} Web</code>, <code>{AppName} Mobile</code>.</p>
    <label class="checkbox-row">
        <input type="checkbox" @bind="EnableDocumentation" @bind:after="SyncState" />
        Documentation — static portal site
    </label>
    <label class="checkbox-row">
        <input type="checkbox" @bind="EnableWeb" @bind:after="OnWebLayerChanged" />
        Web — API, application layers, persistence, optional MVC
    </label>
    @if (EnableWeb)
    {
        <label class="checkbox-row layer-sub">
            <input type="checkbox" @bind="EnableWebAuth" @bind:after="SyncState" />
            Enable API authentication (JWT)
        </label>
    }
    <label class="checkbox-row">
        <input type="checkbox" @bind="EnableMobile" @bind:after="OnMobileLayerChanged" />
        Mobile — Flutter mobile client
    </label>
</fieldset>

<EntityList Entities="Entities"
            SelectedEntity="SelectedEntity"
            SelectedEntityChanged="OnEntitySelected"
            OnStatus="OnEntityStatus"
            OnChanged="OnEntitiesChanged" />

<fieldset class="panel">
    <legend>Properties</legend>
    <EntityPropertyGrid Entity="SelectedEntity"
                        AllEntities="Entities"
                        ClrTypes="ClrTypes"
                        OnChanged="OnPropertyGridChanged" />
</fieldset>

@if (EnableMobile)
{
    <fieldset class="panel mobile-settings-panel">
        <legend>Mobile</legend>
        <div class="form-grid mobile-theme-settings">
            <label>Mobile theme</label>
            <select @bind="MobileThemePreset" @bind:after="SyncState">
                <option value="appgen">AppGen default</option>
                <option value="portal">Match documentation portal</option>
                <option value="cookbook">Cookbook-style</option>
            </select>
        </div>
        <fieldset class="capabilities-panel">
            <legend>Capabilities</legend>
            <p class="hint capability-table-legend">Select what the app should do. <strong>X</strong> = supported on that platform; <strong>—</strong> = not supported.</p>
            <div class="capability-table-wrap">
            <table class="capability-platform-table">
                <CapabilityPlatformTableHead />
                <tbody>
                    <tr class="cap-category-row">
                        <td colspan="5">Options</td>
                    </tr>
                    <tr class="cap-item-row">
                        <td class="cap-name-col">
                            <label class="cap-enable-label" title="SQLite read-through cache when the API is unreachable">
                                <input type="checkbox" @bind="EnableMobileOffline" @bind:after="SyncState" />
                                <span>Offline cache (SQLite)</span>
                            </label>
                        </td>
                        <CapabilityPlatformMatrixCells Definition="@OfflineCacheCapability" />
                    </tr>
                    @foreach (var category in MobileCapabilityCatalog.Categories)
                    {
                        var caps = MobileCapabilityCatalog.GetByCategory(category)
                            .Where(c => c.Id is not (
                                MobileCapabilityId.OfflineCache
                                or MobileCapabilityId.SecureStorage
                                or MobileCapabilityId.JwtAuth
                                or MobileCapabilityId.Internet))
                            .ToList();
                        if (caps.Count == 0)
                        {
                            continue;
                        }

                        <tr class="cap-category-row">
                            <td colspan="5">@category</td>
                        </tr>
                        @foreach (var cap in caps)
                        {
                            var locked = IsCapabilityLocked(cap.Id);
                            <tr class="cap-item-row">
                                <td class="cap-name-col">
                                    <label class="cap-enable-label" title="@(cap.IsImplemented ? cap.Description : "Coming soon")">
                                        <input type="checkbox"
                                               checked="@IsCapabilityEnabled(cap.Id)"
                                               disabled="@(!cap.IsImplemented || locked)"
                                               @onchange="e => ToggleCapability(cap.Id, e.Value is true)" />
                                        <span>
                                            @cap.DisplayName
                                            @if (!cap.IsImplemented)
                                            {
                                                <span class="hint"> (soon)</span>
                                            }
                                        </span>
                                    </label>
                                </td>
                                <CapabilityPlatformMatrixCells Definition="cap" />
                            </tr>
                        }
                    }
                </tbody>
            </table>
            </div>
            @if (HasAnyNativeOnlySelection)
            {
                <p class="hint capability-native-hint">At least one selected capability needs an <strong>Android emulator or device</strong> — Chrome/web will not compile or run those plugins.</p>
            }
        </fieldset>
    </fieldset>
}

<SpecWorkbookPanel OutputRoot="@OutputRoot" ApplicationName="@ApplicationName" OnStatus="OnStatus" OnImported="LoadProject" />

<div class="actions">
    <button type="button" class="btn btn-outline-secondary" @onclick="LoadProject" disabled="@IsBusy">
        Load project
    </button>
    <button type="button" class="btn btn-outline-secondary" @onclick="SaveManifest" disabled="@(!CanSaveManifest)">
        Save manifest
    </button>
    <button type="button" class="btn btn-outline-secondary" @onclick="SaveDraft" disabled="@IsBusy">
        Save draft
    </button>
    <button type="button" class="btn btn-outline-secondary" @onclick="LoadDraft" disabled="@IsBusy">
        Load draft
    </button>
</div>

@code {
    [Parameter] public EventCallback<WorkspaceStatus> OnStatus { get; set; }

    private string ApplicationName { get; set; } = "MyProduct";
    private string? RootNamespace { get; set; }
    private string? Tagline { get; set; }
    private string? Description { get; set; }
    private string OutputRoot { get; set; } = string.Empty;
    private bool EnableDocumentation { get; set; }
    private bool EnableWeb { get; set; } = true;
    private bool EnableWebAuth { get; set; }
    private bool EnableMobile { get; set; }
    private bool EnableMobileOffline { get; set; }
    private string MobileThemePreset { get; set; } = "appgen";
    private DatabaseProvider Database { get; set; } = DatabaseProvider.SqlServer;
    private bool IncludeMvcWeb { get; set; } = true;
    private string ActiveConnectionName { get; set; } = "Dev";
    private string? OracleSchemaPrefix { get; set; }
    private bool EnsureCreatedInDevelopment { get; set; } = true;
    private List<ConfigEntryRow> ConfigEntries { get; } = [new ConfigEntryRow { Name = "Dev", Kind = ConfigEntryKind.ConnectionString, Value = NamingHelper.DefaultDevConnection(DatabaseProvider.SqlServer).Value }];
    private string MobilePackageName { get; set; } = string.Empty;
    private string MobileApiBaseUrl { get; set; } = "http://localhost:5000";
    private readonly HashSet<string> MobileCapabilities = new(StringComparer.OrdinalIgnoreCase);

    private List<EntityDraft> Entities { get; } = [];
    private EntityDraft? SelectedEntity { get; set; }
    private bool IsBusy { get; set; }

    private IReadOnlyList<string> ClrTypes => AppGen.UI.Models.ClrTypeCatalog.GetTypes(Database);

    private bool CanSaveManifest =>
        !IsBusy &&
        !string.IsNullOrWhiteSpace(ApplicationName) &&
        !string.IsNullOrWhiteSpace(OutputRoot) &&
        Entities.Count > 0;

    private string? ResolvedOutputDirectory =>
        ProjectOutputPaths.FindManifestDirectory(OutputRoot, ApplicationName, ProjectOutputLayer.Hub);

    protected override void OnInitialized()
    {
        OutputRoot = FolderService.GetDefaultOutputRoot(HostEnvironment.ContentRootPath);
        if (WizardState.Current is { } shared)
            ApplyDraft(shared, fromWizardOnly: true);
        else
            SyncState();
    }

    private Task OnEntitySelected(EntityDraft? entity)
    {
        SelectedEntity = entity;
        SyncState();
        return Task.CompletedTask;
    }

    private void OnEntitiesChanged()
    {
        SyncState();
        StateHasChanged();
    }

    private void OnPropertyGridChanged()
    {
        SyncState();
        StateHasChanged();
    }

    private async Task OnEntityStatus(string message) =>
        await ReportAsync(message, success: false);

    private async Task LoadProject()
    {
        var dir = WizardState.LastHubDirectory
            ?? ProjectOutputPaths.FindManifestDirectory(OutputRoot, ApplicationName, ProjectOutputLayer.Hub)
            ?? ProjectOutputPaths.HubDirectory(OutputRoot, ApplicationName);
        if (!File.Exists(Path.Combine(dir, "appgen.json")))
        {
            await ReportAsync("appgen.json not found in the output project folder.", success: false);
            return;
        }

        IsBusy = true;
        try
        {
            var spec = await SpecLoader.LoadAsync(dir);
            ApplicationName = spec.ApplicationName;
            RootNamespace = spec.RootNamespace;
            Tagline = spec.Project?.Tagline;
            Description = spec.Project?.Description;
            Database = spec.Database;
            IncludeMvcWeb = spec.UiTargets.HasFlag(UiTarget.MvcWeb);
            ActiveConnectionName = spec.Setup.ActiveConnectionName;
            OracleSchemaPrefix = spec.Setup.OracleSchemaPrefix;
            EnsureCreatedInDevelopment = spec.Setup.EnsureCreatedInDevelopment;
            EnableDocumentation = spec.Targets?.Documentation.Enabled ?? false;
            EnableWeb = spec.Targets?.Web.Enabled ?? true;
            EnableWebAuth = spec.Targets?.Web.Auth.Enabled ?? false;
            EnableMobile = spec.Targets?.Mobile.Enabled ?? false;
            EnableMobileOffline = spec.Targets?.Mobile.Offline.Enabled ?? false;
            MobileThemePreset = spec.Targets?.Mobile.Theme.Preset ?? "appgen";
            MobilePackageName = spec.Targets?.Mobile.PackageName ?? string.Empty;
            MobileApiBaseUrl = spec.Targets?.Mobile.ApiBaseUrl ?? "http://localhost:5000";
            MobileCapabilities.Clear();
            foreach (var id in spec.Targets?.Mobile.Capabilities.Enabled ?? [])
            {
                if (!string.IsNullOrWhiteSpace(id))
                    MobileCapabilities.Add(id.Trim());
            }

            ConfigEntries.Clear();
            foreach (var entry in spec.Setup.ConfigEntries)
            {
                ConfigEntries.Add(new ConfigEntryRow
                {
                    Name = entry.Name,
                    Kind = entry.Kind,
                    Key = entry.Key,
                    Value = entry.Value
                });
            }

            Entities.Clear();
            if (spec.Entities.Count > 0)
                ProjectManifestMapper.ApplyEntitiesToDrafts(Entities, spec.Entities);
            else
                ProjectManifestMapper.ApplySketchesToEntities(Entities, spec.EntitySketches);

            SelectedEntity = Entities.FirstOrDefault();
            SyncState();
            if (spec.Portal is not null)
                WizardState.NotifyManifestLoaded(spec, dir);
            var sectionCount = spec.Portal?.Sections.Count ?? 0;
            var sectionNote = sectionCount > 0 ? $", {sectionCount} portal section(s)" : string.Empty;
            await ReportAsync($"Loaded project from appgen.json ({Entities.Count} entities{sectionNote}).", success: true, dir);
        }
        catch (Exception ex)
        {
            await ReportAsync(ex.Message, success: false);
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task SaveManifest()
    {
        var validationError = EntityValidation.ValidateEntities(Entities);
        if (validationError is not null)
        {
            await ReportAsync(validationError, success: false);
            return;
        }

        IsBusy = true;
        try
        {
            SyncState();
            var dir = ProjectOutputPaths.HubDirectory(OutputRoot, ApplicationName);
            var result = await ManifestSave.SaveAsync(WizardState.ToSolutionSpec(), dir);
            await ReportAsync(result.Message, result.Success, result.ProjectDirectory);
        }
        catch (Exception ex)
        {
            await ReportAsync(ex.Message, success: false);
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task SaveDraft()
    {
        SyncState();
        var draft = WizardState.Current ?? BuildDraft();
        var fileName = string.IsNullOrWhiteSpace(ApplicationName)
            ? "appgen-draft.json"
            : $"{NamingHelper.NormalizeAppName(ApplicationName)}-appgen-draft.json";

        await Js.InvokeVoidAsync("appgen.downloadTextFile", fileName, draft.ToJson(), "application/json");
        await ReportAsync($"Draft saved as {fileName}.", success: true);
    }

    private async Task LoadDraft()
    {
        try
        {
            var json = await Js.InvokeAsync<string?>("appgen.pickTextFile", ".json,application/json");
            if (string.IsNullOrWhiteSpace(json))
                return;

            var draft = WizardDraft.TryParse(json);
            if (draft is null)
            {
                await ReportAsync("Could not read draft file. Expected valid AppGen draft JSON.", success: false);
                return;
            }

            if (draft.SchemaVersion > WizardDraft.CurrentSchemaVersion)
            {
                await ReportAsync($"Draft version {draft.SchemaVersion} is newer than this AppGen UI supports.", success: false);
                return;
            }

            ApplyDraft(draft);
            await ReportAsync($"Draft loaded ({draft.Entities.Count} entities).", success: true);
        }
        catch (Exception ex)
        {
            await ReportAsync(ex.Message, success: false);
        }
    }

    private void ApplyDraft(WizardDraft draft, bool fromWizardOnly = false)
    {
        ApplicationName = draft.ApplicationName;
        RootNamespace = draft.RootNamespace;
        Tagline = draft.Tagline;
        Description = draft.Description;
        if (!fromWizardOnly || string.IsNullOrWhiteSpace(OutputRoot))
        {
            OutputRoot = string.IsNullOrWhiteSpace(draft.OutputRoot)
                ? FolderService.GetDefaultOutputRoot(HostEnvironment.ContentRootPath)
                : draft.OutputRoot;
        }

        Database = draft.Database;
        IncludeMvcWeb = draft.IncludeMvcWeb;
        EnableDocumentation = draft.EnableDocumentation;
        EnableWeb = draft.EnableWeb;
        EnableWebAuth = draft.EnableWebAuth;
        EnableMobile = draft.EnableMobile;
        EnableMobileOffline = draft.EnableMobileOffline;
        MobileThemePreset = draft.MobileThemePreset;
        MobilePackageName = draft.MobilePackageName;
        MobileApiBaseUrl = draft.MobileApiBaseUrl;
        MobileCapabilities.Clear();
        foreach (var id in draft.MobileCapabilities)
            MobileCapabilities.Add(id);
        ActiveConnectionName = draft.ActiveConnectionName;
        OracleSchemaPrefix = draft.OracleSchemaPrefix;
        EnsureCreatedInDevelopment = draft.EnsureCreatedInDevelopment;

        ConfigEntries.Clear();
        foreach (var entry in draft.ConfigEntries)
        {
            ConfigEntries.Add(new ConfigEntryRow
            {
                Name = entry.Name,
                Kind = entry.Kind,
                Key = entry.Key,
                Value = entry.Value
            });
        }

        Entities.Clear();
        foreach (var entityData in draft.Entities)
        {
            var entity = new EntityDraft(entityData.Name)
            {
                IncludeInUi = entityData.IncludeInUi,
                IncludeAuditColumns = entityData.IncludeAuditColumns
            };
            entity.Properties.Clear();
            foreach (var property in entityData.Properties)
            {
                entity.Properties.Add(new PropertyRow
                {
                    Name = property.Name,
                    ClrType = property.ClrType,
                    IsKey = property.IsKey,
                    IsNullable = property.IsNullable,
                    ForeignKeyEntity = property.ForeignKeyEntity
                });
            }
            Entities.Add(entity);
        }

        SelectedEntity = Entities.FirstOrDefault();
        SyncState();
    }

    private WizardDraft BuildDraft() => WizardDraft.FromWizard(
        ApplicationName,
        RootNamespace,
        Database,
        OutputRoot,
        IncludeMvcWeb,
        ActiveConnectionName,
        OracleSchemaPrefix,
        EnsureCreatedInDevelopment,
        ConfigEntries,
        Entities,
        EnableDocumentation,
        EnableWeb,
        EnableMobile,
        EnableWebAuth,
        EnableMobileOffline,
        MobileThemePreset,
        string.IsNullOrWhiteSpace(MobilePackageName) ? null : MobilePackageName,
        MobileApiBaseUrl,
        Tagline,
        Description,
        MobileCapabilities.ToList());

    private bool IsCapabilityEnabled(string id) =>
        MobileCapabilities.Contains(id)
        || (id == MobileCapabilityId.OfflineCache && EnableMobileOffline)
        || (id == MobileCapabilityId.JwtAuth && EnableWebAuth)
        || (id == MobileCapabilityId.SecureStorage && EnableWebAuth);

    private bool IsCapabilityLocked(string id) =>
        id is MobileCapabilityId.OfflineCache or MobileCapabilityId.JwtAuth or MobileCapabilityId.SecureStorage;

    private bool HasAnyNativeOnlySelection =>
        EnableMobileOffline ||
        MobileCapabilities.Any(id =>
        {
            var cap = MobileCapabilityCatalog.TryGet(id);
            return cap is { IsImplemented: true, RequiresNativePlatform: true };
        });

    private static MobileCapabilityDefinition OfflineCacheCapability =>
        MobileCapabilityCatalog.TryGet(MobileCapabilityId.OfflineCache)!;

    private void ToggleCapability(string id, bool enabled)
    {
        if (enabled)
            MobileCapabilities.Add(id);
        else
            MobileCapabilities.Remove(id);
        SyncState();
    }

    public void SyncState()
    {
        WizardState.Update(BuildDraft());
    }

    private void OnWebLayerChanged()
    {
        if (!EnableWeb)
            EnableWebAuth = false;
        SyncState();
    }

    private void OnMobileLayerChanged()
    {
        if (!EnableMobile)
        {
            EnableMobileOffline = false;
            MobileThemePreset = "appgen";
            MobileCapabilities.Clear();
        }
        SyncState();
    }

    private async Task ReportAsync(string message, bool success, string? outputDirectory = null)
    {
        if (OnStatus.HasDelegate)
            await OnStatus.InvokeAsync(new WorkspaceStatus(message, success, outputDirectory));
    }

    public void Dispose() => SyncState();
}
