@page "/mobile"
@using AppGen.Core
@using AppGen.Core.Models
@using AppGen.Engine
@using AppGen.UI.Models
@using AppGen.UI.Services
@inject MobileGenerationService MobileService
@inject ManifestSaveService ManifestSave
@inject OutputFolderService FolderService
@inject WizardStateService WizardState
@inject IWebHostEnvironment HostEnvironment
@inject IJSRuntime Js
@implements IDisposable

<PageTitle>AppGen — Mobile</PageTitle>

<PageHeader Title="Mobile"
            Subtitle="Generate a Flutter proof-of-concept from entities defined on the Web tab or saved manifest."
            Badge="Flutter POC" />

<div class="wizard">
    @if (WizardState.HasData)
    {
        <p class="status-inline status-success">Using @WizardState.EntityNames.Count shared entities from the Web tab.</p>
    }
    else
    {
        <p class="muted">Define entities on the <a href="web">Web</a> tab, click <strong>Save manifest</strong>, or load a draft here.</p>
    }

    <fieldset class="panel">
        <legend>Application</legend>
        <div class="form-grid">
            <label>Application name</label>
            <input @bind="ApplicationName" />

            <label>Package name</label>
            <input @bind="PackageName" placeholder="com.myapp.app" />

            <label>API base URL</label>
            <input @bind="ApiBaseUrl" />

            <label>Output folder</label>
            <input @bind="OutputRoot" />

            <label>Entity</label>
            <select @bind="SelectedEntityName">
                @if (EntityNames.Count == 0)
                {
                    <option value="">No entities — save manifest or load draft</option>
                }
                @foreach (var name in EntityNames)
                {
                    <option value="@name">@name</option>
                }
            </select>
        </div>
        <p class="hint">State management: Riverpod (POC). Architecture: feature folders with Dio HTTP client.</p>
    </fieldset>

    <div class="actions">
        <button type="button" class="btn btn-outline-secondary" @onclick="LoadProject" disabled="@IsWorking">Load project</button>
        <button type="button" class="btn btn-outline-secondary" @onclick="LoadDraft" disabled="@IsWorking">Load draft</button>
        <button type="button" class="btn btn-outline-secondary" @onclick="SaveManifest" disabled="@(!CanSaveManifest)">Save manifest</button>
        <button type="button" class="btn btn-primary" @onclick="GenerateMobile" disabled="@(!CanGenerate)">
            @(IsWorking ? "Generating…" : "Generate mobile")
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(StatusMessage))
    {
        <div class="status-panel @(IsSuccess ? "status-success" : "status-error")">
            <div><strong>Status</strong></div>
            <div>@StatusMessage</div>
            @if (!string.IsNullOrWhiteSpace(OutputDirectory))
            {
                <div class="output-block">
                    <code>@OutputDirectory</code>
                    <div class="hint">Output: <code>mobile/flutter/</code> — open with Flutter SDK when ready.</div>
                </div>
            }
        </div>
    }
</div>

@code {
    private string ApplicationName { get; set; } = "MyProduct";
    private string PackageName { get; set; } = "com.myproduct.app";
    private string ApiBaseUrl { get; set; } = "https://localhost:5001";
    private string OutputRoot { get; set; } = string.Empty;
    private string SelectedEntityName { get; set; } = string.Empty;
    private List<string> EntityNames { get; } = [];

    private bool IsWorking { get; set; }
    private string StatusMessage { get; set; } = string.Empty;
    private bool IsSuccess { get; set; }
    private string? OutputDirectory { get; set; }

    private bool CanGenerate =>
        !IsWorking &&
        !string.IsNullOrWhiteSpace(ApplicationName) &&
        !string.IsNullOrWhiteSpace(OutputRoot) &&
        !string.IsNullOrWhiteSpace(SelectedEntityName);

    private bool CanSaveManifest =>
        !IsWorking &&
        !string.IsNullOrWhiteSpace(ApplicationName) &&
        !string.IsNullOrWhiteSpace(OutputRoot) &&
        EntityNames.Count > 0;

    protected override void OnInitialized()
    {
        OutputRoot = FolderService.GetDefaultOutputRoot(HostEnvironment.ContentRootPath);
        PackageName = $"com.{ApplicationName.ToLowerInvariant()}.app";
        WizardState.Changed += OnWizardStateChanged;
        ApplySharedState();
    }

    private void OnWizardStateChanged() => InvokeAsync(() =>
    {
        ApplySharedState();
        StateHasChanged();
    });

    private void ApplySharedState()
    {
        if (WizardState.Current is not { } draft)
            return;

        if (!string.IsNullOrWhiteSpace(draft.ApplicationName))
            ApplicationName = draft.ApplicationName;
        if (!string.IsNullOrWhiteSpace(draft.OutputRoot))
            OutputRoot = draft.OutputRoot;

        PackageName = $"com.{ApplicationName.ToLowerInvariant()}.app";
        EntityNames.Clear();
        EntityNames.AddRange(draft.Entities.Select(e => e.Name));
        if (string.IsNullOrWhiteSpace(SelectedEntityName) || !EntityNames.Contains(SelectedEntityName))
            SelectedEntityName = EntityNames.FirstOrDefault() ?? string.Empty;
    }

    private string? ResolvedOutputDirectory
    {
        get
        {
            try
            {
                return Path.GetFullPath(Path.Combine(OutputRoot.Trim(), NamingHelper.NormalizeAppName(ApplicationName.Trim())));
            }
            catch
            {
                return null;
            }
        }
    }

    private async Task LoadProject()
    {
        var dir = ResolvedOutputDirectory;
        if (dir is null || !File.Exists(Path.Combine(dir, "appgen.json")))
        {
            StatusMessage = "appgen.json not found in the output project folder.";
            IsSuccess = false;
            return;
        }

        try
        {
            var spec = await SpecLoader.LoadAsync(dir);
            ApplicationName = spec.ApplicationName;
            ApiBaseUrl = spec.Targets?.Mobile.ApiBaseUrl ?? ApiBaseUrl;
            PackageName = spec.Targets?.Mobile.PackageName ?? $"com.{spec.ApplicationName.ToLowerInvariant()}.app";
            EntityNames.Clear();
            EntityNames.AddRange(spec.Entities.Select(e => e.Name));
            SelectedEntityName = EntityNames.FirstOrDefault() ?? string.Empty;
            StatusMessage = $"Loaded {EntityNames.Count} entities from manifest.";
            IsSuccess = true;
            OutputDirectory = dir;
            UpdateSharedStateFromManifest(spec);
        }
        catch (Exception ex)
        {
            StatusMessage = ex.Message;
            IsSuccess = false;
        }
    }

    private async Task LoadDraft()
    {
        try
        {
            var json = await Js.InvokeAsync<string?>("appgen.pickTextFile", ".json,application/json");
            if (string.IsNullOrWhiteSpace(json))
                return;

            var draft = WizardDraft.TryParse(json);
            if (draft is null)
            {
                StatusMessage = "Could not read draft file. Expected valid AppGen draft JSON.";
                IsSuccess = false;
                return;
            }

            WizardState.Update(draft);
            ApplySharedState();
            StatusMessage = $"Draft loaded ({draft.Entities.Count} entities).";
            IsSuccess = true;
        }
        catch (Exception ex)
        {
            StatusMessage = ex.Message;
            IsSuccess = false;
        }
    }

    private async Task SaveManifest()
    {
        var dir = ResolvedOutputDirectory;
        if (dir is null)
        {
            StatusMessage = "Output folder is invalid.";
            IsSuccess = false;
            return;
        }

        if (!WizardState.HasData)
        {
            StatusMessage = "No entities to save. Load a draft or define entities on the Web tab first.";
            IsSuccess = false;
            return;
        }

        try
        {
            var result = await ManifestSave.SaveAsync(WizardState.ToSolutionSpec(), dir);
            StatusMessage = result.Message;
            IsSuccess = result.Success;
            OutputDirectory = result.ProjectDirectory;
        }
        catch (Exception ex)
        {
            StatusMessage = ex.Message;
            IsSuccess = false;
        }
    }

    private async Task GenerateMobile()
    {
        IsWorking = true;
        StatusMessage = string.Empty;
        IsSuccess = false;
        try
        {
            SolutionSpec spec;
            if (WizardState.HasData)
                spec = WizardState.ToSolutionSpec();
            else
            {
                var dir = ResolvedOutputDirectory;
                if (dir is not null && File.Exists(Path.Combine(dir, "appgen.json")))
                    spec = await SpecLoader.LoadAsync(dir);
                else
                    spec = SpecLoader.CreateDefault(ApplicationName, ApplicationName, DatabaseProvider.SqlServer);
            }

            if (spec.Entities.Count == 0 && !string.IsNullOrWhiteSpace(SelectedEntityName))
            {
                spec = new SolutionSpec
                {
                    SchemaVersion = spec.SchemaVersion,
                    ApplicationName = spec.ApplicationName,
                    RootNamespace = spec.RootNamespace,
                    Phase = spec.Phase,
                    Portal = spec.Portal,
                    EntitySketches = spec.EntitySketches,
                    Targets = spec.Targets,
                    Generation = spec.Generation,
                    Database = spec.Database,
                    UiTargets = spec.UiTargets,
                    Setup = spec.Setup,
                    Entities =
                    [
                        new EntitySpec
                        {
                            Name = SelectedEntityName,
                            IncludeInUi = true,
                            Properties =
                            [
                                new PropertySpec { Name = NamingHelper.ToKeyPropertyName(SelectedEntityName), ClrType = "long", IsKey = true },
                                new PropertySpec { Name = "Name", ClrType = "string" }
                            ]
                        }
                    ]
                };
            }

            var result = await MobileService.GenerateAsync(
                spec,
                OutputRoot.Trim(),
                SelectedEntityName,
                PackageName,
                ApiBaseUrl);

            StatusMessage = result.Message;
            IsSuccess = result.Success;
            OutputDirectory = result.OutputDirectory;
        }
        catch (Exception ex)
        {
            StatusMessage = ex.Message;
            IsSuccess = false;
        }
        finally
        {
            IsWorking = false;
        }
    }

    private void UpdateSharedStateFromManifest(SolutionSpec spec)
    {
        var entities = new List<EntityDraft>();
        ProjectManifestMapper.ApplyEntitiesToDrafts(entities, spec.Entities);
        WizardState.Update(WizardDraft.FromWizard(
            spec.ApplicationName,
            spec.RootNamespace,
            spec.Database,
            OutputRoot,
            spec.UiTargets.HasFlag(UiTarget.MvcWeb),
            spec.Setup.ActiveConnectionName,
            spec.Setup.OracleSchemaPrefix,
            spec.Setup.EnsureCreatedInDevelopment,
            spec.Setup.ConfigEntries.Select(e => new ConfigEntryRow
            {
                Name = e.Name,
                Kind = e.Kind,
                Key = e.Key,
                Value = e.Value
            }),
            entities));
    }

    public void Dispose() => WizardState.Changed -= OnWizardStateChanged;
}
