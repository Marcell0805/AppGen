@page "/"
@using AppGen.Core.Models
@using AppGen.UI.Models
@using AppGen.UI.Services
@inject AppGenerationService Generator
@inject OutputFolderService FolderService
@inject IJSRuntime Js

<PageTitle>AppGen</PageTitle>

<h1>AppGen</h1>
<p class="subtitle">Generate a layered ASP.NET Core API solution with optional Blazor Web UI.</p>

<div class="wizard">
    <fieldset class="panel">
        <legend>Application</legend>
        <div class="form-grid">
            <label>App name</label>
            <input @bind="ApplicationName" />

            <label>Root namespace</label>
            <input @bind="RootNamespace" placeholder="Defaults to app name" />

            <label>Database</label>
            <select @bind="Database">
                <option value="@DatabaseProvider.SqlServer">SqlServer</option>
                <option value="@DatabaseProvider.Oracle">Oracle</option>
            </select>

            <label>Output folder</label>
            <input @bind="OutputRoot" placeholder="Must be empty — existing files block generate" />
        </div>
    </fieldset>

    <fieldset class="panel">
        <legend>Client UI (optional)</legend>
        <label class="checkbox-row">
            <input type="checkbox" checked="@IncludeBlazorWeb" @onchange="OnBlazorWebChanged" />
            Blazor Web — entity list and edit pages (calls API via HttpClient)
        </label>
        <label class="checkbox-row muted">
            <input type="checkbox" disabled />
            WinForms — coming in a later phase
        </label>
    </fieldset>

    <EntityList Entities="Entities"
                SelectedEntity="SelectedEntity"
                SelectedEntityChanged="OnEntitySelected"
                OnStatus="SetStatus" />

    <fieldset class="panel">
        <legend>Properties</legend>
        <EntityPropertyGrid Entity="SelectedEntity"
                            ClrTypes="ClrTypes"
                            OnChanged="StateHasChanged" />
    </fieldset>

    <div class="actions">
        <button type="button" class="btn btn-primary" @onclick="Generate" disabled="@(!CanGenerate)">
            @(IsGenerating ? "Generating…" : "Generate")
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(StatusMessage))
    {
        <div class="status-panel @(IsSuccess ? "status-success" : "status-error")">
            <div><strong>Status</strong></div>
            <div>@StatusMessage</div>
            @if (!string.IsNullOrWhiteSpace(OutputDirectory))
            {
                <div class="output-block">
                    <div><strong>Output</strong></div>
                    <code>@OutputDirectory</code>
                    <div class="output-actions">
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="CopyPath">Copy path</button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="OpenFolder">Open folder</button>
                    </div>
                    <div class="hint">Next: <code>cd "@OutputDirectory"</code> then <code>dotnet build</code></div>
                </div>
            }
        </div>
    }
</div>

@code {
    private string ApplicationName { get; set; } = "InventorySystem";
    private string? RootNamespace { get; set; }
    private DatabaseProvider Database { get; set; } = DatabaseProvider.SqlServer;
    private string OutputRoot { get; set; } = Path.Combine(
        Environment.GetFolderPath(Environment.SpecialFolder.DesktopDirectory), "AppGenOutput");

    private bool IncludeBlazorWeb { get; set; }
    private List<EntityDraft> Entities { get; } = [];
    private EntityDraft? SelectedEntity { get; set; }

    private bool IsGenerating { get; set; }
    private string StatusMessage { get; set; } = string.Empty;
    private bool IsSuccess { get; set; }
    private string? OutputDirectory { get; set; }

    private IReadOnlyList<string> ClrTypes => ClrTypeCatalog.GetTypes(Database);

    private bool CanGenerate =>
        !IsGenerating &&
        !string.IsNullOrWhiteSpace(ApplicationName) &&
        !string.IsNullOrWhiteSpace(OutputRoot);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            var settings = await Js.InvokeAsync<WizardSettings?>("appgen.loadSettings", Array.Empty<object>());
            if (settings is null) return;
            if (!string.IsNullOrWhiteSpace(settings.ApplicationName))
                ApplicationName = settings.ApplicationName;
            if (!string.IsNullOrWhiteSpace(settings.OutputRoot))
                OutputRoot = settings.OutputRoot;
            IncludeBlazorWeb = settings.IncludeBlazorWeb;
            StateHasChanged();
        }
        catch
        {
            // localStorage unavailable
        }
    }

    private void OnBlazorWebChanged(ChangeEventArgs e) =>
        IncludeBlazorWeb = e.Value is true;

    private Task OnEntitySelected(EntityDraft? entity)
    {
        SelectedEntity = entity;
        return Task.CompletedTask;
    }

    private void SetStatus(string message)
    {
        StatusMessage = message;
        IsSuccess = false;
    }

    private string? ValidateEntities()
    {
        foreach (var entity in Entities)
        {
            var names = entity.Properties
                .Select(p => p.Name.Trim())
                .Where(n => n.Length > 0)
                .ToList();

            if (names.Distinct(StringComparer.OrdinalIgnoreCase).Count() != names.Count)
                return $"Duplicate property names on entity {entity.Name}.";

            var keyCount = entity.Properties.Count(p => p.IsKey);
            if (keyCount != 1)
                return $"Entity {entity.Name} must have exactly one key property.";

            if (names.Count == 0)
                return $"Entity {entity.Name} must have at least one property.";
        }

        return null;
    }

    private async Task Generate()
    {
        var validationError = ValidateEntities();
        if (validationError is not null)
        {
            StatusMessage = validationError;
            IsSuccess = false;
            OutputDirectory = null;
            return;
        }

        IsGenerating = true;
        StatusMessage = string.Empty;
        OutputDirectory = null;
        IsSuccess = false;

        try
        {
            var uiTargets = IncludeBlazorWeb ? UiTarget.BlazorWeb : UiTarget.None;
            var entities = Entities.Select(e => e.ToSpec()).ToList();
            var result = await Generator.GenerateAsync(
                ApplicationName.Trim(),
                string.IsNullOrWhiteSpace(RootNamespace) ? null : RootNamespace.Trim(),
                Database,
                uiTargets,
                OutputRoot.Trim(),
                entities);

            StatusMessage = result.Message;
            IsSuccess = result.Success;
            OutputDirectory = result.OutputDirectory;

            if (result.Success)
            {
                await Js.InvokeVoidAsync("appgen.saveSettings", new WizardSettings
                {
                    ApplicationName = ApplicationName,
                    OutputRoot = OutputRoot,
                    IncludeBlazorWeb = IncludeBlazorWeb
                });
            }
        }
        catch (Exception ex)
        {
            StatusMessage = ex.Message;
            IsSuccess = false;
        }
        finally
        {
            IsGenerating = false;
        }
    }

    private async Task CopyPath()
    {
        if (string.IsNullOrWhiteSpace(OutputDirectory)) return;
        await Js.InvokeVoidAsync("appgen.copyToClipboard", OutputDirectory);
        StatusMessage = "Path copied to clipboard.";
        IsSuccess = true;
    }

    private void OpenFolder()
    {
        if (string.IsNullOrWhiteSpace(OutputDirectory)) return;
        try
        {
            FolderService.OpenFolder(OutputDirectory);
        }
        catch (Exception ex)
        {
            StatusMessage = ex.Message;
            IsSuccess = false;
        }
    }

    private sealed class WizardSettings
    {
        public string? ApplicationName { get; set; }
        public string? OutputRoot { get; set; }
        public bool IncludeBlazorWeb { get; set; }
    }
}
